# Decision Logic

```{r decision}
#| cache: false
total_pns_unwt   <- freq_table %>%
  filter(pcs_code == "ROLLUP: Any 01QM (Repair, PNS)") %>%
  pull(unweighted_n)

total_cns_unwt   <- freq_table %>%
  filter(pcs_code == "ROLLUP: Any 00QM (CNS neg ctrl)") %>%
  pull(unweighted_n)

total_any_unwt   <- freq_table %>%
  filter(pcs_code == "ROLLUP: Any facial nerve (union)") %>%
  pull(unweighted_n)

total_any_wt     <- freq_table %>%
  filter(pcs_code == "ROLLUP: Any facial nerve (union)") %>%
  pull(weighted_n)

pct_miscoded <- round(100 * total_cns_unwt / total_any_unwt, 1)

decision <- case_when(
  total_any_unwt >= 200 ~
    "VIABLE: Inpatient capture supports a parallel cohort. Proceed with co-occurring procedure profiling on the NIS arm.",
  total_any_unwt >= 50  ~
    "MARGINAL: Inpatient capture supports limited descriptive analysis but co-occurring procedure profiling will be underpowered. Consider pooling additional NIS years.",
  TRUE ~
    "REFRAME: Total too low for parallel cohort. Recommend reframing NIS arm as a brief descriptive comparator and treating NASS as the primary database."
)

cat(sprintf(paste0(
  "── Inpatient facial nerve summary ─────────────────────────────\n",
  "  Correctly coded PNS (01QM) — unweighted:   %d\n",
  "  Miscoded CNS (00QM) — unweighted:          %d  (%.1f%% of total)\n",
  "  Total (union, all sections) — unweighted:  %d\n",
  "  Total (union, all sections) — weighted:    %.1f\n\n",
  "DECISION: %s\n"),
  total_pns_unwt, total_cns_unwt, pct_miscoded,
  total_any_unwt, total_any_wt, decision))
```

