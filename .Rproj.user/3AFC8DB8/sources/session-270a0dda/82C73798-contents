# Publication Table (HCUP Suppression Applied)

```{r pub-table}
#| cache: false
suppress <- function(u, w) {
  if      (u == 0L) paste0("0 (0)")
  else if (u < hcup_suppress_threshold)
    paste0("<11 (suppressed)")
  else    paste0(format(u, big.mark=","), " (", format(round(w), big.mark=","), ")")
}

results_pub <- results %>%
  rowwise() %>%
  mutate(display = suppress(unweighted_n, weighted_n)) %>%
  ungroup() %>%
  select(category, display)

gt_trauma <- results_pub %>%
  setNames(c("Category", "Unweighted N (Weighted national estimate)")) %>%
  gt() %>%
  tab_header(
    title    = md("**NIS 2023: Traumatic vs. Non-Traumatic Facial Nerve Repair**"),
    subtitle = md("*Deduplicated case counts with survey-weighted national estimates*")
