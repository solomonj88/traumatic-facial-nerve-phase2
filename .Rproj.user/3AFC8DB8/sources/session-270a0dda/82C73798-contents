# Data Extraction

```{r extract}
#| cache: false
stopifnot(file.exists(nis_core_asc))

message("Reading NIS_2023_Core.ASC (diagnosis + procedure fields)...")
message("Estimated time: 5\u201310 minutes.")

core <- read_fwf(
  file          = nis_core_asc,
  col_positions = col_spec,
  col_types     = cols(
    HOSP_NIS    = col_integer(),
    NIS_STRATUM = col_integer(),
    DISCWT      = col_double(),
    .default    = col_character()
  ),
  na = c("", " ")
)

core <- core %>%
  mutate(
    HOSP_NIS    = if_else(HOSP_NIS    %in% HOSP_NIS_NA, NA_integer_, HOSP_NIS),
    NIS_STRATUM = if_else(NIS_STRATUM %in% STRATUM_NA,  NA_integer_, NIS_STRATUM),
    DISCWT      = if_else(DISCWT      %in% DISCWT_NA,   NA_real_,    DISCWT)
  )

dx_cols <- grep("^I10_DX[0-9]+$", names(core), value=TRUE)
pr_cols <- grep("^I10_PR[0-9]+$", names(core), value=TRUE)
core    <- core %>% mutate(across(all_of(c(dx_cols, pr_cols)), trimws))

message("Rows loaded: ", format(nrow(core), big.mark=","))
```

# Identify and Classify the 57 Facial Nerve Repair Cases

```{r classify}
#| cache: false

# ── Step 1: Flag facial nerve repair encounters ───────────────────────────────
flag_any_code <- function(df, codes, fields) {
  as.integer(rowSums(
    sapply(fields, function(col) df[[col]] %in% codes, USE.NAMES=FALSE)
  ) > 0)
}

core$has_correct_pcs  <- flag_any_code(core, pcs_correct,  pr_cols)
core$has_miscoded_pcs <- flag_any_code(core, pcs_miscoded, pr_cols)
core$facial_nerve_any <- as.integer(
  (core$has_correct_pcs + core$has_miscoded_pcs) > 0
)

fn_cases <- core %>% filter(facial_nerve_any == 1L) %>%
  mutate(pcs_group = case_when(
    has_correct_pcs == 1L & has_miscoded_pcs == 1L ~ "Both sections",
    has_correct_pcs == 1L                           ~ "PNS (correct, 01QM)",
    has_miscoded_pcs == 1L                          ~ "CNS (miscoded, 00QM)"
  ))

cat(sprintf("Total facial nerve repair cases: %d\n", nrow(fn_cases)))

# ── Step 2: Apply trauma flags (per-criterion, then union) ───────────────────
flag_dx_regex <- function(df, regex, dx_cols) {
  as.integer(rowSums(
    sapply(dx_cols, function(col)
      grepl(regex, df[[col]]), USE.NAMES=FALSE),
    na.rm = TRUE
  ) > 0)
}

for (flag_name in names(trauma_flags)) {
  fn_cases[[paste0("trauma_", flag_name)]] <-
    flag_dx_regex(fn_cases, trauma_flags[[flag_name]], dx_cols)
}

# Union: traumatic if ANY criterion met
flag_cols <- paste0("trauma_", names(trauma_flags))
fn_cases$is_traumatic <- as.integer(
  rowSums(fn_cases[, flag_cols, drop=FALSE]) > 0
)
fn_cases$is_nontraumatic <- as.integer(fn_cases$is_traumatic == 0L)

# ── Step 3: Report per-criterion and union counts ────────────────────────────
cat("\n── Per-criterion trauma flags (may overlap) ───────────────\n")
for (flag_name in names(trauma_flags)) {
  n <- sum(fn_cases[[paste0("trauma_", flag_name)]])
  cat(sprintf("  %-45s %d\n", flag_name, n))
}
cat(sprintf("\n  %-45s %d\n", "UNION (any criterion \u2014 unique cases):",
            sum(fn_cases$is_traumatic)))
cat(sprintf("  %-45s %d\n", "Non-traumatic:",
            sum(fn_cases$is_nontraumatic)))
```

# Survey-Weighted Estimates

```{r survey-estimates}
#| cache: false
options(survey.lonely.psu = "adjust")

# Helper: weighted N from a subset of core rows
weighted_n <- function(row_indices) {
  if (length(row_indices) == 0L) return(0)
  svy <- svydesign(
    ids     = ~HOSP_NIS,
    strata  = ~NIS_STRATUM,
    weights = ~DISCWT,
    data    = core[row_indices, c("HOSP_NIS","NIS_STRATUM","DISCWT")],
    nest    = TRUE
  )
  round(sum(weights(svy)), 1)
}

fn_idx        <- which(core$facial_nerve_any == 1L)
traumatic_idx <- which(core$facial_nerve_any == 1L &
                       fn_cases$is_traumatic[match(seq_along(fn_idx), seq_along(fn_idx))] == 1L)

# Rebuild flags on core for indexing
core$is_traumatic_fn <- 0L
core$is_traumatic_fn[fn_idx] <- fn_cases$is_traumatic

traumatic_core_idx    <- which(core$facial_nerve_any == 1L & core$is_traumatic_fn == 1L)
nontraumatic_core_idx <- which(core$facial_nerve_any == 1L & core$is_traumatic_fn == 0L)
pns_traumatic_idx     <- which(core$has_correct_pcs  == 1L &
                                core$has_miscoded_pcs == 0L &
                                core$is_traumatic_fn  == 1L)
cns_traumatic_idx     <- which(core$has_miscoded_pcs == 1L &
                                core$has_correct_pcs  == 0L &
                                core$is_traumatic_fn  == 1L)

# Per-criterion weighted Ns
per_criterion_wt <- sapply(names(trauma_flags), function(flag_name) {
  flag_col <- paste0("trauma_", flag_name)
  core[[paste0("tmp_", flag_col)]] <<- 0L
  hit_idx <- fn_idx[fn_cases[[flag_col]] == 1L]
  core[[paste0("tmp_", flag_col)]][hit_idx] <<- 1L
  weighted_n(hit_idx)
})
# Cleanup temp columns
for (flag_name in names(trauma_flags))
  core[[paste0("tmp_trauma_", flag_name)]] <- NULL

results <- tibble(
  category        = c(
    "All facial nerve repair (any code)",
    "  PNS correctly coded (01QM)",
    "  CNS miscoded (00QM)",
    paste0("  Traumatic \u2014 ", names(trauma_flags)[1], " only"),
    paste0("  Traumatic \u2014 ", names(trauma_flags)[2], " only"),
    paste0("  Traumatic \u2014 ", names(trauma_flags)[3], " only"),
    "TRAUMATIC \u2014 any criterion (unique, deduplicated)",
    "  Of which: CNS-miscoded traumatic",
    "  Of which: PNS-correct traumatic",
    "NON-TRAUMATIC (no trauma criterion met)"
  ),
  unweighted_n    = c(
    nrow(fn_cases),
    sum(fn_cases$pcs_group == "PNS (correct, 01QM)"),
    sum(fn_cases$pcs_group == "CNS (miscoded, 00QM)"),
    sum(fn_cases[[paste0("trauma_", names(trauma_flags)[1])]]),
    sum(fn_cases[[paste0("trauma_", names(trauma_flags)[2])]]),
    sum(fn_cases[[paste0("trauma_", names(trauma_flags)[3])]]),
    sum(fn_cases$is_traumatic),
    length(cns_traumatic_idx),
    length(pns_traumatic_idx),
    sum(fn_cases$is_nontraumatic)
  ),
  weighted_n      = c(
    weighted_n(fn_idx),
    weighted_n(which(core$has_correct_pcs == 1L & core$has_miscoded_pcs == 0L)),
    weighted_n(which(core$has_miscoded_pcs == 1L & core$has_correct_pcs == 0L)),
    per_criterion_wt[1],
    per_criterion_wt[2],
    per_criterion_wt[3],
    weighted_n(traumatic_core_idx),
    weighted_n(cns_traumatic_idx),
    weighted_n(pns_traumatic_idx),
    weighted_n(nontraumatic_core_idx)
  )
)

cat("\n── Survey-weighted results ─────────────────────────────────\n")
print(results, n=Inf)
```

