# Decision Summary

```{r decision}
#| cache: false
traumatic_unwt <- sum(fn_cases$is_traumatic)
traumatic_wt   <- weighted_n(traumatic_core_idx)
nontraumatic_unwt <- sum(fn_cases$is_nontraumatic)
nontraumatic_wt   <- weighted_n(nontraumatic_core_idx)
total_unwt <- nrow(fn_cases)
total_wt   <- weighted_n(fn_idx)
pct_traumatic <- round(100 * traumatic_unwt / total_unwt, 1)

cat(sprintf(paste0(
  "── FINAL TRAUMATIC FACIAL NERVE REPAIR ESTIMATE (NIS 2023) ──\n\n",
  "  Total facial nerve repair cases:     %d unweighted  /  %.1f weighted\n",
  "  Traumatic (any criterion):           %d unweighted  /  %.1f weighted\n",
  "  Non-traumatic:                       %d unweighted  /  %.1f weighted\n",
  "  Traumatic fraction:                  %.1f%% of all cases\n\n",
  "  NOTE: 'Any criterion' is the deduplicated union of S04.5,\n",
  "  S01.4/S01.8, and external-cause V01-Y99. A patient carrying\n",
  "  all three codes is counted once.\n"
), total_unwt, total_wt,
   traumatic_unwt, traumatic_wt,
   nontraumatic_unwt, nontraumatic_wt,
   pct_traumatic))
