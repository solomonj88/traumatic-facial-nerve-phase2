  "/Users/solomon/Library/CloudStorage/OneDrive-UW/Research projects/",
  "NASS traumatic facial nerve repair project/Data/",
  "HCUP Original Data Files 21 through 23/HCUP NIS/NIS_2023/",
  "NIS_2023_Core.ASC"
)

# ── Column positions (bytes) from StataLoad_NIS_2023_Core.Do (12/10/2025) ────
#
#   Variable      Cols      Type    Notes
#   HOSP_NIS      1–5       long    Hospital ID; cluster variable for svydesign
#   NIS_STRATUM   16–19     int     Sampling stratum
#   DISCWT        31–41     double  Raw integer stored with 7 implied decimals
#   I10_PR1       355–361   str     7-character ICD-10-PCS code
#   I10_PR2       362–368
#   ...
#   I10_PR25      523–529

col_spec <- fwf_cols(
  HOSP_NIS    = c(1,   5),
  NIS_STRATUM = c(16,  19),
  DISCWT      = c(31,  41),
  I10_PR1     = c(355, 361),
  I10_PR2     = c(362, 368),
  I10_PR3     = c(369, 375),
  I10_PR4     = c(376, 382),
  I10_PR5     = c(383, 389),
  I10_PR6     = c(390, 396),
  I10_PR7     = c(397, 403),
  I10_PR8     = c(404, 410),
  I10_PR9     = c(411, 417),
  I10_PR10    = c(418, 424),
  I10_PR11    = c(425, 431),
  I10_PR12    = c(432, 438),
  I10_PR13    = c(439, 445),
  I10_PR14    = c(446, 452),
  I10_PR15    = c(453, 459),
  I10_PR16    = c(460, 466),
  I10_PR17    = c(467, 473),
  I10_PR18    = c(474, 480),
  I10_PR19    = c(481, 487),
  I10_PR20    = c(488, 494),
  I10_PR21    = c(495, 501),
  I10_PR22    = c(502, 508),
  I10_PR23    = c(509, 515),
  I10_PR24    = c(516, 522),
  I10_PR25    = c(523, 529)
)

# DISCWT: stored as a raw integer with 7 implied decimal places in the ASC.
# e.g. the value 52631579 in the file represents a weight of 5.2631579.
# Sentinel values from Stata do-file: -999999999/-888888888/-666666666 → NA.
DISCWT_SCALE <- 1e7
DISCWT_NA    <- c(-999999999, -888888888, -666666666)

# Other HCUP missing-value sentinels (from Stata recode section)
HOSP_NIS_NA  <- c(-9999, -8888, -6666)
STRATUM_NA   <- c(-999,  -888,  -666)

# ICD-10-PCS target code lists
pcs_repair_pns     <- c("01QM0ZZ","01QM3ZZ","01QM4ZZ")
pcs_supplement     <- c("01UM07Z","01UM0KZ","01UM0JZ")
pcs_reposition     <- c("01SM0ZZ")
pcs_repair_cns_neg <- c("00QM0ZZ","00QM3ZZ","00QM4ZZ")
all_codes          <- c(pcs_repair_pns, pcs_supplement,
                        pcs_reposition, pcs_repair_cns_neg)

hcup_suppress_threshold <- 11L
```

# Data Extraction

```{r extract}
#| cache: true
stopifnot(file.exists(nis_core_asc))

message("Reading NIS_2023_Core.ASC (4.34 GB — selected columns only)...")
message("Estimated time on typical SSD: 3–8 minutes.")

core <- read_fwf(
  file          = nis_core_asc,
  col_positions = col_spec,
  col_types     = cols(
    HOSP_NIS    = col_integer(),
    NIS_STRATUM = col_integer(),
    DISCWT      = col_double(),
    .default    = col_character()   # all I10_PR fields
  ),
  na = c("", " ")
)

message("Rows loaded: ", format(nrow(core), big.mark=","))

# ── Apply HCUP missing-value recoding ────────────────────────────────────────
core <- core %>%
  mutate(
    HOSP_NIS    = if_else(HOSP_NIS    %in% HOSP_NIS_NA, NA_integer_, HOSP_NIS),
    NIS_STRATUM = if_else(NIS_STRATUM %in% STRATUM_NA,  NA_integer_, NIS_STRATUM),
    DISCWT      = if_else(DISCWT      %in% DISCWT_NA,   NA_real_,
                          DISCWT / DISCWT_SCALE)
  )

# Trim whitespace padding from all procedure code fields
pr_cols <- grep("^I10_PR[0-9]+$", names(core), value=TRUE)
core    <- core %>% mutate(across(all_of(pr_cols), trimws))

message("Procedure fields: ", length(pr_cols))
message("Discharges with valid DISCWT: ",
        format(sum(!is.na(core$DISCWT)), big.mark=","))
```

# Code Flagging

```{r flag-codes}
#| cache: true
flag_code <- function(df, code, pr_cols) {
  as.integer(rowSums(
    sapply(pr_cols, function(col)
      !is.na(df[[col]]) & df[[col]] == code,
      USE.NAMES = FALSE),
    na.rm = TRUE
  ) > 0)
}

flag_any <- function(df, codes, pr_cols) {
  if (length(codes) == 0L) return(rep(0L, nrow(df)))
  as.integer(rowSums(
    sapply(codes, function(cd) flag_code(df, cd, pr_cols),
           USE.NAMES = FALSE)
  ) > 0)
}

for (cd in all_codes) {
  core[[paste0("flag_", cd)]] <- flag_code(core, cd, pr_cols)
}

core$any_repair_pns     <- flag_any(core, pcs_repair_pns,     pr_cols)
core$any_supplement     <- flag_any(core, pcs_supplement,     pr_cols)
core$any_reposition     <- flag_any(core, pcs_reposition,     pr_cols)
core$any_repair_cns_neg <- flag_any(core, pcs_repair_cns_neg, pr_cols)
core$any_facial_nerve   <- as.integer(
  (core$any_repair_pns + core$any_supplement + core$any_reposition) > 0
)

message("── Unweighted counts ──────────────────────────────────────")
message("  Any facial nerve (union):  ", sum(core$any_facial_nerve))
message("  01QM Repair (PNS):         ", sum(core$any_repair_pns))
message("  01UM Supplement:           ", sum(core$any_supplement))
message("  01SM Reposition:           ", sum(core$any_reposition))
message("  00QM CNS neg control:      ", sum(core$any_repair_cns_neg))
```

# Survey Design

```{r survey-design}
# HCUP NIS: stratify on NIS_STRATUM, cluster on HOSP_NIS, weight by DISCWT.
# nest=TRUE because HOSP_NIS values repeat across strata (not globally unique).
# lonely.psu="adjust" prevents errors when rare-code subsets reduce a stratum
# to a single PSU.
options(survey.lonely.psu = "adjust")

svy_nis <- svydesign(
  ids     = ~HOSP_NIS,
  strata  = ~NIS_STRATUM,
  weights = ~DISCWT,
  data    = core,
  nest    = TRUE
)
```

# Frequency Table

```{r frequencies}
#| cache: false
summarise_code <- function(code) {
  flag_var <- paste0("flag_", code)
  unwt_n   <- sum(core[[flag_var]], na.rm=TRUE)
  wt_est   <- if (unwt_n > 0L)
    as.numeric(svytotal(as.formula(paste0("~", flag_var)),
                        svy_nis, na.rm=TRUE)[1])
  else 0
  tibble(pcs_code=code, unweighted_n=unwt_n, weighted_n=round(wt_est))
}

summarise_rollup <- function(label, flag_var) {
  unwt_n <- sum(core[[flag_var]], na.rm=TRUE)
  wt_est <- if (unwt_n > 0L)
    as.numeric(svytotal(as.formula(paste0("~", flag_var)),
                        svy_nis, na.rm=TRUE)[1])
  else 0
  tibble(pcs_code=label, unweighted_n=unwt_n, weighted_n=round(wt_est))
}

per_code <- map_dfr(all_codes, summarise_code)

rollups <- bind_rows(
  summarise_rollup("ROLLUP: Any 01QM (Repair, PNS)",      "any_repair_pns"),
  summarise_rollup("ROLLUP: Any 01UM (Supplement, Open)", "any_supplement"),
  summarise_rollup("ROLLUP: Any 01SM (Reposition, Open)", "any_reposition"),
  summarise_rollup("ROLLUP: Any 00QM (CNS neg ctrl)",     "any_repair_cns_neg"),
  summarise_rollup("ROLLUP: Any facial nerve (union)",    "any_facial_nerve")
)

desc_lookup <- c(
  "01QM0ZZ" = "Repair Facial Nerve, Open (PNS \u2014 correct section)",
  "01QM3ZZ" = "Repair Facial Nerve, Percutaneous (PNS \u2014 correct section)",
  "01QM4ZZ" = "Repair Facial Nerve, Percutaneous Endoscopic (PNS \u2014 correct section)",
  "01UM07Z" = "Supplement Facial Nerve, Open, Autologous Tissue Substitute",
  "01UM0KZ" = "Supplement Facial Nerve, Open, Nonautologous Tissue Substitute",
  "01UM0JZ" = "Supplement Facial Nerve, Open, Synthetic Substitute",
  "01SM0ZZ" = "Reposition Facial Nerve, Open",
  "00QM0ZZ" = "Repair Facial Nerve, Open (CNS \u2014 negative control, expect 0)",
  "00QM3ZZ" = "Repair Facial Nerve, Percutaneous (CNS \u2014 negative control)",
  "00QM4ZZ" = "Repair Facial Nerve, Percutaneous Endoscopic (CNS \u2014 negative control)"
)

per_code <- per_code %>%
  mutate(description = desc_lookup[pcs_code]) %>%
  select(pcs_code, description, unweighted_n, weighted_n)

rollups <- rollups %>%
  mutate(description = "") %>%
  select(pcs_code, description, unweighted_n, weighted_n)

freq_table <- bind_rows(per_code, rollups)
```

# Apply HCUP Cell Suppression

```{r suppress}
#| cache: false
# HCUP DUA: unweighted N 1–10 must be suppressed in published output.
# freq_table (unsuppressed) is for analyst decision-making only.

freq_pub <- freq_table %>%
  mutate(
    unweighted_n_disp = case_when(
      unweighted_n == 0L                     ~ "0",
      unweighted_n < hcup_suppress_threshold ~ "<11 (suppressed)",
      TRUE ~ format(unweighted_n, big.mark=",")
    ),
    weighted_n_disp = case_when(
      unweighted_n == 0L                     ~ "0",
      unweighted_n < hcup_suppress_threshold ~ "Suppressed",
      TRUE ~ format(weighted_n, big.mark=",")
    )
  ) %>%
  select(pcs_code, description, unweighted_n_disp, weighted_n_disp)
```

