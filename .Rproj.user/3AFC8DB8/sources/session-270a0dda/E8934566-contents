hcup_suppress <- function(unwt, wt) {
  if (unwt == 0L)            list(u="0",                w="0")
  else if (unwt < 11L)       list(u="<11 (suppressed)", w="Suppressed")
  else                       list(u=format(unwt, big.mark=","),
                                  w=format(wt,   big.mark=","))
}

profile_pub <- profile %>%
  rowwise() %>%
  mutate(
    pns_disp = list(hcup_suppress(`PNS (correct) (unwt)`,  `PNS (correct) (wt)`)),
    cns_disp = list(hcup_suppress(`CNS (miscoded) (unwt)`, `CNS (miscoded) (wt)`)),
    bth_disp = list(hcup_suppress(`Both sections (unwt)`,  `Both sections (wt)`))
  ) %>%
  ungroup() %>%
  mutate(
    pns_str = paste0(map_chr(pns_disp, "u"), " (", map_chr(pns_disp, "w"), ")"),
    cns_str = paste0(map_chr(cns_disp, "u"), " (", map_chr(cns_disp, "w"), ")"),
