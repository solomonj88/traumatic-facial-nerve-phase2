```{r flag-dx}
#| cache: false
# For each case, check whether ANY of its 40 diagnosis fields matches each
# category's regex prefix. trimws already applied during load.

flag_dx_category <- function(df, regex, dx_cols) {
  as.integer(rowSums(
    sapply(dx_cols, function(col)
      grepl(regex, df[[col]]), USE.NAMES=FALSE),
    na.rm = TRUE
  ) > 0)
}

for (cat_name in names(dx_categories)) {
  fn_cases[[paste0("dx_", cat_name)]] <-
    flag_dx_category(fn_cases, dx_categories[[cat_name]], dx_cols)
}

supports_cols <- paste0("dx_", names(dx_categories)[category_polarity == "supports"])
refutes_cols  <- paste0("dx_", names(dx_categories)[category_polarity == "refutes"])

fn_cases$any_supporting_dx <- as.integer(
  rowSums(fn_cases[, supports_cols, drop=FALSE]) > 0
)
fn_cases$any_refuting_dx   <- as.integer(
  rowSums(fn_cases[, refutes_cols, drop=FALSE]) > 0
)
