# Data Extraction

```{r extract}
#| cache: false
stopifnot(file.exists(nis_core_asc))

message("Reading NIS_2023_Core.ASC with diagnosis + procedure fields...")
message("Estimated time: 5\u201310 minutes (more columns than v1.0).")

core <- read_fwf(
  file          = nis_core_asc,
  col_positions = col_spec,
  col_types     = cols(
    HOSP_NIS    = col_integer(),
    NIS_STRATUM = col_integer(),
    DISCWT      = col_double(),
    .default    = col_character()
  ),
  na = c("", " ")
)

core <- core %>%
  mutate(
    HOSP_NIS    = if_else(HOSP_NIS    %in% HOSP_NIS_NA, NA_integer_, HOSP_NIS),
    NIS_STRATUM = if_else(NIS_STRATUM %in% STRATUM_NA,  NA_integer_, NIS_STRATUM),
    DISCWT      = if_else(DISCWT      %in% DISCWT_NA,   NA_real_,    DISCWT)
  )

dx_cols <- grep("^I10_DX[0-9]+$", names(core), value=TRUE)
pr_cols <- grep("^I10_PR[0-9]+$", names(core), value=TRUE)
core    <- core %>% mutate(across(all_of(c(dx_cols, pr_cols)), trimws))

message("Rows loaded: ", format(nrow(core), big.mark=","))
message("Diagnosis fields: ", length(dx_cols),
        "; Procedure fields: ", length(pr_cols))
```

# Identify the 57 Facial Nerve Repair Cases

```{r identify-cases}
#| cache: false
flag_any_code <- function(df, codes, fields) {
  as.integer(rowSums(
    sapply(fields, function(col) df[[col]] %in% codes, USE.NAMES=FALSE)
  ) > 0)
}

core$has_correct_pcs  <- flag_any_code(core, pcs_correct,  pr_cols)
core$has_miscoded_pcs <- flag_any_code(core, pcs_miscoded, pr_cols)
core$facial_nerve_any <- as.integer(
  (core$has_correct_pcs + core$has_miscoded_pcs) > 0
)

fn_cases <- core %>% filter(facial_nerve_any == 1L)

fn_cases <- fn_cases %>%
  mutate(group = case_when(
    has_correct_pcs == 1L & has_miscoded_pcs == 1L ~ "Both sections",
    has_correct_pcs == 1L                           ~ "PNS (correct)",
    has_miscoded_pcs == 1L                          ~ "CNS (miscoded)"
  ))

cat("── Facial nerve repair cases identified ───────────────────\n")
cat(sprintf("  PNS correct (01QM):   %d\n", sum(fn_cases$group == "PNS (correct)")))
cat(sprintf("  CNS miscoded (00QM):  %d\n", sum(fn_cases$group == "CNS (miscoded)")))
cat(sprintf("  Both sections:        %d\n", sum(fn_cases$group == "Both sections")))
cat(sprintf("  TOTAL:                %d\n", nrow(fn_cases)))
