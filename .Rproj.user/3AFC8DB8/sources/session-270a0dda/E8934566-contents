# Verdict

```{r verdict}
#| cache: false
cns_total      <- sum(fn_cases$group == "CNS (miscoded)")
cns_supporting <- sum(fn_cases$group == "CNS (miscoded)" &
                      fn_cases$any_supporting_dx == 1L)
cns_refuting   <- sum(fn_cases$group == "CNS (miscoded)" &
                      fn_cases$any_refuting_dx == 1L)

pns_total      <- sum(fn_cases$group == "PNS (correct)")
pns_supporting <- sum(fn_cases$group == "PNS (correct)" &
                      fn_cases$any_supporting_dx == 1L)

pct <- function(x, n) if (n > 0) sprintf("%.1f%%", 100 * x / n) else "n/a"

cat("── Hypothesis test verdict ─────────────────────────────────\n\n")
cat(sprintf("CNS-miscoded cases (n=%d):\n", cns_total))
cat(sprintf("  With \u22651 facial-nerve-consistent diagnosis:  %d (%s)\n",
            cns_supporting, pct(cns_supporting, cns_total)))
cat(sprintf("  With \u22651 negative-control diagnosis:        %d (%s)\n",
            cns_refuting, pct(cns_refuting, cns_total)))
cat(sprintf("  With NO facial-nerve-consistent diagnosis:  %d (%s)\n\n",
            cns_total - cns_supporting, pct(cns_total - cns_supporting, cns_total)))

cat(sprintf("PNS-correct cases (n=%d):\n", pns_total))
cat(sprintf("  With \u22651 facial-nerve-consistent diagnosis:  %d (%s)\n\n",
            pns_supporting, pct(pns_supporting, pns_total)))

verdict <- case_when(
  cns_total == 0 ~
    "INDETERMINATE: no CNS cases to evaluate.",
  (cns_supporting / cns_total) >= 0.70 ~
    "CONFIRMED: \u226570% of CNS-section cases carry diagnoses consistent with facial nerve pathology, supporting the systematic miscoding hypothesis.",
  (cns_supporting / cns_total) >= 0.40 ~
    "PARTIALLY CONFIRMED: A substantial fraction of CNS-section cases carry facial-nerve-consistent diagnoses, but a sizeable minority do not.",
  TRUE ~
    "NOT CONFIRMED: The diagnostic profile does not predominantly point to facial nerve pathology. The miscoding hypothesis must be revised."
)

cat("VERDICT: ", verdict, "\n")
