# Diagnostic Profile Comparison

```{r dx-profile-table}
#| cache: false
build_profile <- function(cases, category_names) {
  options(survey.lonely.psu = "adjust")
  rows <- list()

  for (cat_name in category_names) {
    flag_var <- paste0("dx_", cat_name)
    regex    <- dx_categories[[cat_name]]
    row <- list(category = cat_name,
                polarity = category_polarity[cat_name])

    for (grp in c("PNS (correct)", "CNS (miscoded)", "Both sections")) {
      sub    <- cases[cases$group == grp, ]
      n_unwt <- sum(sub[[flag_var]], na.rm = TRUE)

      if (n_unwt > 0L) {
        grp_rows <- switch(grp,
          "PNS (correct)"  = which(core$has_correct_pcs  == 1L &
                                   core$has_miscoded_pcs == 0L),
          "CNS (miscoded)" = which(core$has_miscoded_pcs == 1L &
                                   core$has_correct_pcs  == 0L),
          "Both sections"  = which(core$has_correct_pcs  == 1L &
                                   core$has_miscoded_pcs == 1L)
        )
        dx_hit <- rowSums(
          sapply(dx_cols, function(col)
            grepl(regex, core[[col]][grp_rows]),
          USE.NAMES = FALSE),
          na.rm = TRUE) > 0
        hit_rows <- grp_rows[dx_hit]

        if (length(hit_rows) > 0L) {
          sub_svy <- svydesign(
            ids     = ~HOSP_NIS,
            strata  = ~NIS_STRATUM,
            weights = ~DISCWT,
            data    = core[hit_rows, c("HOSP_NIS","NIS_STRATUM","DISCWT")],
            nest    = TRUE
          )
          n_wt <- round(sum(weights(sub_svy)), 1)
        } else {
          n_wt <- 0
        }
      } else {
        n_wt <- 0
      }

      row[[paste0(grp, " (unwt)")]] <- n_unwt
      row[[paste0(grp, " (wt)")]]   <- n_wt
    }
    rows[[cat_name]] <- row
  }
  bind_rows(rows)
}

profile <- build_profile(fn_cases, names(dx_categories))

profile <- profile %>%
  mutate(polarity = factor(polarity, levels=c("supports","refutes"))) %>%
  arrange(polarity, category)

profile %>%
  select(category, polarity,
         `PNS (correct) (unwt)`, `PNS (correct) (wt)`,
         `CNS (miscoded) (unwt)`, `CNS (miscoded) (wt)`,
         `Both sections (unwt)`, `Both sections (wt)`) %>%
  kable(
    caption = paste0("INTERNAL ONLY \u2014 Co-occurring diagnosis profile by ",
                     "PCS section assignment. HCUP NIS 2023."),
    col.names = c("Diagnosis category","Polarity",
                  "PNS unwt","PNS wt",
                  "CNS unwt","CNS wt",
                  "Both unwt","Both wt"),
    format.args = list(big.mark = ",")
  ) %>%
  kable_styling(bootstrap_options=c("striped","hover","condensed"),
                full_width=TRUE) %>%
  row_spec(which(profile$polarity == "supports"), background="#E8F4E8") %>%
  row_spec(which(profile$polarity == "refutes"),  background="#FBE8E8")
