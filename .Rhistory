# Distribution of DISCWT after the divide-by-1e7 transformation
summary(core$DISCWT)
library(readr)
nis_core_asc <- paste0(
"/Users/solomon/Library/CloudStorage/OneDrive-UW/Research projects/",
"NASS traumatic facial nerve repair project/Data/",
"HCUP Original Data Files 21 through 23/HCUP NIS/NIS_2023/",
"NIS_2023_Core.ASC"
)
# Read just 100 rows — takes seconds
test <- read_fwf(
file          = nis_core_asc,
col_positions = fwf_cols(DISCWT = c(31, 41)),
col_types     = cols(DISCWT = col_double()),
n_max         = 100
)
# Show raw values — before any scaling
summary(test$DISCWT)
head(test$DISCWT, 20)
# What does the total look like if we DON'T divide?
cat("Sum if no scaling:      ", sum(test$DISCWT, na.rm=TRUE), "\n")
cat("Sum if divide by 1e7:   ", sum(test$DISCWT / 1e7, na.rm=TRUE), "\n")
cat("Sum if divide by 1e4:   ", sum(test$DISCWT / 1e4, na.rm=TRUE), "\n")
